# Copy to `.env` (or export in your shell / set in PyCharm run config).
#
# Both of these are REQUIRED on Windows. Linux/macOS users can ignore them.
#
# 1. PYTHONUTF8=1 — fvcore reads YAML with the default Python text codec,
#    which on Windows is cp936 (zh_CN) / cp1252 (en_US). The Detectron2
#    model-zoo YAMLs contain UTF-8 characters and crash without this.
PYTHONUTF8=1

# 2. KMP_DUPLICATE_LIB_OK=TRUE — torch, numpy, and matplotlib each ship
#    their own copy of OpenMP. On Windows the runtime aborts when it sees
#    more than one libiomp loaded. Setting this to TRUE tells OpenMP to
#    pick one and continue. (It is *not* needed when only one of these is
#    imported at a time, but `train.py` / viz scripts import all three.)
KMP_DUPLICATE_LIB_OK=TRUE
